# ─────────────────────────────────────────────────────────────────────────────
# RIFT — Environment Variables
# Copy this file to .env and fill in the required values.
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# GitHub personal access token with repo + workflow scopes.
# Used to clone private repos and push the AI_Fix branch.
GITHUB_TOKEN=ghp_your_token_here

# Google Gemini API key.  Used by the FixGeneratorAgent for LLM-powered repairs
# of TYPE_ERROR and LOGIC bugs.  Get yours at https://aistudio.google.com/
GEMINI_API_KEY=AIzaSyBL0J140IW8-LeJFRfpOPm5m42HpCtYwCs

# ── Optional ──────────────────────────────────────────────────────────────────

# Maximum number of fix-retry attempts per run (1–50, default 5).
MAX_RETRIES=5

# Optional API key.  When set, all non-health endpoints require X-RIFT-KEY header.
RIFT_API_KEY=
