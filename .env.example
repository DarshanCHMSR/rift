# ─────────────────────────────────────────────────────────────────────────────
# RIFT — Environment Variables
# Copy this file to .env and fill in the required values.
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# GitHub personal access token with repo + workflow scopes.
# Used to clone private repos and push the AI_Fix branch.
GITHUB_TOKEN=ghp_your_token_here

# OpenAI API key.  Used by the FixGeneratorAgent for LLM-assisted repairs.
OPENAI_API_KEY=sk-your_key_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Maximum number of fix-retry attempts per run (1–50, default 5).
MAX_RETRIES=5
